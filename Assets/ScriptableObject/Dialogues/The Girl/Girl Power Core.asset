    waitAfterLine: 0
  - isPlayer: 1
    speakerName: 
    text: hmm
    waitAfterLine: 0
  - isPlayer: 0
    speakerName: 
    text: You know what?
    waitAfterLine: 0
  - isPlayer: 0
    speakerName: 
    text: I want to do one thing.
    waitAfterLine: 0
  - isPlayer: 0
    speakerName: 
    text: Could you...
    waitAfterLine: 0
  - isPlayer: 0
    speakerName: 
    text: Climb to the top of the tallest mountain
    waitAfterLine: 0
  - isPlayer: 1
    speakerName: 
    text: and see the sunset?
    waitAfterLine: 0
