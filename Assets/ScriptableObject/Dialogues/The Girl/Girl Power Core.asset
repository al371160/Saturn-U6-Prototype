    speakerName: 
    text: OK, I'll do that.
    waitAfterLine: 0
  - isPlayer: 1
    speakerName: 
    text: (Wow, this girl is quite peculiar)
    waitAfterLine: 0
  - isPlayer: 1
    speakerName: 
    text: (I wonder if I can spot the station she's on)
    waitAfterLine: 0
