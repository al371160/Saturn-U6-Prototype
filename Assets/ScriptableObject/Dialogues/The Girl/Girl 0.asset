    speakerName: 
    text: (^0_0^)
    waitAfterLine: 0
  - isPlayer: 0
    speakerName: 
    text: ...
    waitAfterLine: 0
  - isPlayer: 1
    speakerName: 
    text: Haha, having trouble?
    waitAfterLine: 0
  - isPlayer: 0
    speakerName: 
    text: Oh, you have no idea!
    waitAfterLine: 0
  - isPlayer: 0
    speakerName: 
    text: It's like having three more days to live?
    waitAfterLine: 0
  - isPlayer: 1
    speakerName: 
    text: LOL, not three, only two
    waitAfterLine: 0
