  lines:
  - isPlayer: 1
    speakerName: 
    text: ...
    waitAfterLine: 0
  - isPlayer: 0
    speakerName: 
    text: You've been awarded a two-day leave to Earth
    waitAfterLine: 0
  - isPlayer: 1
    speakerName: 
    text: ...
    waitAfterLine: 0
  - isPlayer: 0
    speakerName: 
    text: Congratulations! You should be proud.
    waitAfterLine: 0
  - isPlayer: 0
    speakerName: 
    text: Your work rate has been superb.
    waitAfterLine: 0
  - isPlayer: 0
    speakerName: 
    text: A department record.
    waitAfterLine: 1
  - isPlayer: 0
    speakerName: 
    text: We'd like to thank you for it.
    waitAfterLine: 1
  - isPlayer: 1
    speakerName: 
    text: ...
    waitAfterLine: 1
  - isPlayer: 1
    speakerName: 
    text: Thank you.
    waitAfterLine: 1
  - isPlayer: 0
    speakerName: 
    text: There's been a lot of accidents
    waitAfterLine: 1
  - isPlayer: 0
    speakerName: 
    text: among earth travelers. Runaways, I assume.
    waitAfterLine: 1
  - isPlayer: 0
    speakerName: 
    text: Not everyone is suited
    waitAfterLine: 1
  - isPlayer: 0
    speakerName: 
    text: for the purposeful life of our company.
    waitAfterLine: 1
  - isPlayer: 0
    speakerName: 
    text: Now enjoy yourself.
    waitAfterLine: 1
  - isPlayer: 0
    speakerName: 
    text: Exit is to the back of the ship.
    waitAfterLine: 1
  - isPlayer: 1
    speakerName: 
    text: Understood sir. Th--
    waitAfterLine: 1
  - isPlayer: 0
    speakerName: 
    text: Oh! Before you go,
    waitAfterLine: 1
  - isPlayer: 0
    speakerName: 
    text: Take the Eyes,
    waitAfterLine: 1
  - isPlayer: 0
    speakerName: 
    text: They're in your inventory
    waitAfterLine: 1
  - isPlayer: 0
    speakerName: 
    text: 'Just press [TAB]'
    waitAfterLine: 1
  - isPlayer: 0
    speakerName: 
    text: Enjoy a bit of company, eh?
    waitAfterLine: 1
  - isPlayer: 1
    speakerName: 
    text: ... Yes sir
    waitAfterLine: 1
  choices:
  - choiceText: I will
